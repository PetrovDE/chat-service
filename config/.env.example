# ============================================
# REQUIRED CORE SETTINGS
# ============================================

# PostgreSQL connection strings
DATABASE_URL=postgresql+asyncpg://llama_chat_user:change_me@localhost:5432/llama_chat_db
ALEMBIC_DATABASE_URL=postgresql://llama_chat_user:change_me@localhost:5432/llama_chat_db

# JWT secret (generate a strong random value for real deployments)
JWT_SECRET_KEY=change_me_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_MIN_LENGTH=8

# CORS
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000


# ============================================
# SERVER / LOGGING
# ============================================

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
LOG_LEVEL=INFO

# Optional compatibility settings
APP_ENV=production
APP_SECRET_KEY=


# ============================================
# PROVIDER ROUTING / MODELS
# ============================================

# Local development default.
# Use `aihub` in environments where AI HUB is configured and preferred.
DEFAULT_MODEL_SOURCE=local

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama / local provider
# IMPORTANT: OLLAMA_HOST / OLLAMA_MODEL are obsolete and intentionally removed.
EMBEDDINGS_BASEURL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_CHAT_MODEL_CATALOG=llama3.2:latest,phi4:latest
OLLAMA_EMBED_MODEL_CATALOG=nomic-embed-text:latest,qwen3-emb,mxbai-embed-large
EMBEDDINGS_MODEL=nomic-embed-text:latest
EMBEDDINGS_DIM=0
EMBEDDING_MODEL_DIMENSIONS=aihub:qwen3-emb=4096
MODEL_INVALID_OVERRIDE_POLICY=fallback_default
EMBEDDING_PREFLIGHT_VALIDATE=true
OLLAMA_EMBED_MAX_INPUT_CHARS=3500
OLLAMA_EMBED_SEGMENT_OVERLAP_CHARS=250

# AI HUB (optional)
AIHUB_URL=
AIHUB_KEYCLOAK_HOST=
AIHUB_USERNAME=
AIHUB_PASSWORD=
AIHUB_CLIENT_ID=
AIHUB_CLIENT_SECRET=
AIHUB_REQUEST_TIMEOUT=120
AIHUB_VERIFY_SSL=false
AIHUB_DEFAULT_MODEL=vikhr
AIHUB_EMBEDDING_MODEL=qwen3-emb
AIHUB_CHAT_MODEL_CATALOG=
AIHUB_EMBED_MODEL_CATALOG=qwen3-emb,arctic
AIHUB_CHAT_STREAM_PATH=
AIHUB_MAX_PROMPT_CHARS=50000
AIHUB_MAX_HISTORY_MESSAGE_CHARS=2000

# Provider fallback / resilience policy
LLM_FALLBACK_POLICY_VERSION=p1-aihub-first-v1
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_RESTRICTED_CLASSES=restricted
AIHUB_CIRCUIT_WINDOW_SECONDS=60
AIHUB_CIRCUIT_MIN_REQUESTS=4
AIHUB_CIRCUIT_FAILURE_RATIO=0.5
AIHUB_CIRCUIT_OPEN_SECONDS=30
AIHUB_CIRCUIT_HALF_OPEN_MAX_REQUESTS=1

# Corporate API bridge (optional)
CORPORATE_API_URL=
CORPORATE_API_USERNAME=
CORPORATE_API_TOKEN=


# ============================================
# FILE LIFECYCLE / RUNTIME PATHS
# ============================================

SUPPORTED_FILETYPES=pdf,docx,txt,md,csv,tsv,json,xlsx,xls
MAX_FILESIZE_MB=50
USER_FILE_QUOTA_BYTES=1073741824

FILE_PIPELINE_VERSION_DEFAULT=pipeline-v1
FILE_PARSER_VERSION_DEFAULT=parser-v1
FILE_ARTIFACT_VERSION_DEFAULT=artifact-v1
FILE_CHUNKING_STRATEGY_DEFAULT=smart
FILE_RETRIEVAL_PROFILE_DEFAULT=default

RUNTIME_ROOT=runtime
RUNTIME_RAW_FILES_DIR=runtime/raw_files
RUNTIME_TEMP_UPLOADS_DIR=runtime/temp_uploads
RUNTIME_FILE_ARTIFACTS_DIR=runtime/file_artifacts
RUNTIME_PUBLIC_UPLOADS_DIR=runtime/public/uploads
RUNTIME_EXPORTS_DIR=runtime/exports
RUNTIME_LOCAL_INDEX_DIR=runtime/local_index
INGESTION_QUEUE_SQLITE_PATH=runtime/queue/.ingestion_jobs.sqlite3


# ============================================
# RETRIEVAL / RAG STABILITY
# ============================================

DEFAULT_LLM_MODE=local
DEFAULT_RAG_MODEL=llama3.1:8b
MAX_CHUNKS_PER_FILE=100
SPLITTER_TYPE=smart
CHUNK_SIZE=2000
CHUNK_OVERLAP=400
EMBEDDING_CONCURRENCY=6
AIHUB_EMBEDDING_CONCURRENCY=3

VECTORDB_PATH=runtime/vector/chromadb
VECTORDB_EPHEMERAL_MODE=false
COLLECTION_NAME=documents
RAG_SCORE_THRESHOLD=0.0

RAG_FETCH_K_MULTIPLIER=10
RAG_FETCH_K_MIN=40
RAG_LEXICAL_POOL_MULTIPLIER=3
RAG_LEXICAL_POOL_MIN=120
RAG_LEXICAL_POOL_MAX=1200
RAG_FULL_FILE_MAX_CHUNKS=800
RAG_FULL_FILE_MIN_ROW_COVERAGE=0.95
RAG_FULL_FILE_ESCALATION_MAX_CHUNKS=2000

RAG_DYNAMIC_TOPK_ENABLED=true
RAG_DYNAMIC_SHORT_QUERY_MAX_TOKENS=4
RAG_DYNAMIC_TOPK_SHORT_RATIO=0.20
RAG_DYNAMIC_TOPK_FACT_RATIO=0.10
RAG_DYNAMIC_TOPK_BROAD_RATIO=0.30
RAG_DYNAMIC_TOPK_MIN=8
RAG_DYNAMIC_TOPK_MAX=96
RAG_DYNAMIC_COVERAGE_MIN_RATIO=0.35
RAG_DYNAMIC_ESCALATION_ENABLED=true
RAG_DYNAMIC_ESCALATION_MULTIPLIER=2.0
RAG_DYNAMIC_ESCALATION_MAX_TOPK=192
RAG_DYNAMIC_ESCALATE_TO_FULL_FILE_MAX_CHUNKS=120

FULL_FILE_MAP_BATCH_MAX_DOCS=12
FULL_FILE_MAP_BATCH_MAX_CHARS=25000
FULL_FILE_MAP_MAX_TOKENS=900
FULL_FILE_MAP_MAX_BATCHES=300
FULL_FILE_DIRECT_CONTEXT_MAX_CHUNKS=24
FULL_FILE_DIRECT_CONTEXT_MAX_CHARS=42000
FULL_FILE_REDUCE_CONTEXT_MAX_CHARS=22000
FULL_FILE_REDUCE_TARGET_GROUPS=8
FULL_FILE_REDUCE_MAX_ROUNDS=4
CHAT_HISTORY_MAX_MESSAGES=30

XLSX_CHUNK_MAX_CHARS=3500
XLSX_CHUNK_MAX_ROWS=40
XLSX_MAX_COLUMNS_PER_CHUNK=0
XLSX_CELL_MAX_CHARS=0
TABULAR_ROW_GROUP_ROWS_NARROW=200
TABULAR_ROW_GROUP_ROWS_MEDIUM=100
TABULAR_ROW_GROUP_ROWS_WIDE=50
TABULAR_ROW_GROUP_MEDIUM_COLUMNS_THRESHOLD=12
TABULAR_ROW_GROUP_WIDE_COLUMNS_THRESHOLD=40
TABULAR_MAX_EMBEDDING_DOCS=320
TABULAR_SUMMARY_TOP_COLUMNS=12
TABULAR_COLUMN_SUMMARY_ENABLED=true
TABULAR_COLUMN_SUMMARY_MAX_COLUMNS=6
TABULAR_WIDE_CELL_HARD_LIMIT=2000


# ============================================
# INGESTION WORKER RELIABILITY
# ============================================

INGESTION_BAD_CHUNK_RATIO_THRESHOLD=0.35
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_BASE_SECONDS=2.0
INGESTION_RETRY_MAX_SECONDS=60.0
INGESTION_WORKER_POLL_INTERVAL_SECONDS=0.5
INGESTION_WORKER_LEASE_SECONDS=120.0
INGESTION_WORKER_HEARTBEAT_SECONDS=5.0
INGESTION_WORKER_SHUTDOWN_TIMEOUT_SECONDS=15.0


# ============================================
# TABULAR LANGGRAPH / DETERMINISTIC SQL BACKEND
# ============================================

TABULAR_RUNTIME_ROOT=runtime/tabular_runtime/datasets
TABULAR_RUNTIME_CATALOG_PATH=runtime/tabular_runtime/catalog.duckdb
TABULAR_SQL_TIMEOUT_SECONDS=8.0
TABULAR_SQL_MAX_RESULT_ROWS=200
TABULAR_SQL_MAX_RESULT_BYTES=200000
TABULAR_SQL_MAX_SCANNED_ROWS=1000000
TABULAR_SQL_MAX_CHARS=4000
TABULAR_PROFILE_MAX_COLUMNS=160

TABULAR_LLM_GUARDED_PLANNER_ENABLED=false
TABULAR_LLM_GUARDED_MAX_ATTEMPTS=3
TABULAR_LLM_GUARDED_PLAN_TIMEOUT_SECONDS=5.0
TABULAR_LLM_GUARDED_EXECUTION_TIMEOUT_SECONDS=5.0
TABULAR_LLM_GUARDED_PLAN_MAX_TOKENS=800
TABULAR_LLM_GUARDED_EXECUTION_MAX_TOKENS=700


# ============================================
# COMPLEX ANALYTICS EXECUTION
# ============================================

COMPLEX_ANALYTICS_TIMEOUT_SECONDS=12.0
COMPLEX_ANALYTICS_MAX_OUTPUT_CHARS=16000
COMPLEX_ANALYTICS_MAX_ARTIFACTS=16
COMPLEX_ANALYTICS_MAX_ARTIFACTS_HARD_CAP=48
COMPLEX_ANALYTICS_MAX_ROWS=200000
COMPLEX_ANALYTICS_ARTIFACT_DIR=runtime/public/uploads/complex_analytics
COMPLEX_ANALYTICS_ARTIFACT_TTL_HOURS=168
COMPLEX_ANALYTICS_ARTIFACT_MAX_RUN_DIRS=2000

COMPLEX_ANALYTICS_CODEGEN_ENABLED=true
COMPLEX_ANALYTICS_CODEGEN_FORCE_LOCAL=false
COMPLEX_ANALYTICS_CODEGEN_PLAN_TIMEOUT_SECONDS=6.0
COMPLEX_ANALYTICS_CODEGEN_PLAN_TIMEOUT_SECONDS_AIHUB_POLICY=14.0
COMPLEX_ANALYTICS_CODEGEN_PLAN_MAX_TOKENS=900
COMPLEX_ANALYTICS_CODEGEN_TIMEOUT_SECONDS=8.0
COMPLEX_ANALYTICS_CODEGEN_TIMEOUT_SECONDS_AIHUB_POLICY=24.0
COMPLEX_ANALYTICS_CODEGEN_MAX_TOKENS=2200
COMPLEX_ANALYTICS_RESPONSE_TIMEOUT_SECONDS=10.0
COMPLEX_ANALYTICS_RESPONSE_TIMEOUT_SECONDS_AIHUB_POLICY=20.0
COMPLEX_ANALYTICS_RESPONSE_MAX_TOKENS=1800
COMPLEX_ANALYTICS_PREFER_LOCAL_COMPOSER_FOR_BROAD_QUERY=true

# Deprecated compatibility flags retained by config model (intentionally unused)
COMPLEX_ANALYTICS_ALLOW_TEMPLATE_FALLBACK=false
COMPLEX_ANALYTICS_ALLOW_TEMPLATE_RUNTIME_FALLBACK=false


# ============================================
# OBSERVABILITY / CACHE / OPTIONAL LANGSMITH
# ============================================

ENABLE_POST_ANSWER_SUMMARIZE=false
ENABLE_CACHE=true

# Optional LangSmith tracing for LangGraph runs
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_PROJECT=llama-service
LANGSMITH_TAGS=tabular-langgraph


# ============================================
# OPTIONAL EVAL ENV GATES (ONLINE/HYBRID)
# ============================================

# Used by online eval datasets; leave blank if not running those slices.
EVAL_COMPLEX_ANALYTICS_CONVERSATION_ID=
EVAL_RAG_MULTIDOC_CONVERSATION_ID=
EVAL_RAG_INDEXING_CONVERSATION_ID=
EVAL_TABULAR_FOLLOWUP_CONVERSATION_ID=
